	<true/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.nitay.Audiopig</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>audiopig</string>
			</array>
		</dict>
	</array>
